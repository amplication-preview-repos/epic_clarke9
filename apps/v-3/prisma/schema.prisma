datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Ad {
  adsGroupId  String    @map("ads_group_id") @db.VarChar
  adsId       String    @map("ads_id") @db.VarChar
  campaign    String?   @map("campaign") @db.VarChar
  company     String?   @map("company") @db.VarChar
  content     String?   @map("content") @db.VarChar
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  createdById String?   @map("created_by_id") @db.Uuid
  endDate     DateTime  @map("end_date") @db.Timestamp(6)
  id          String    @id @default(uuid()) @map("id") @db.Uuid
  image       String?   @map("image") @db.VarChar
  isDeleted   Boolean   @default(false) @map("is_deleted")
  lang        String    @default("en") @map("lang") @db.VarChar
  pages       String?   @map("pages") @db.VarChar
  sortNo      Int?      @default(0) @map("sort_no")
  startDate   DateTime  @map("start_date") @db.Timestamp(6)
  title       String?   @map("title") @db.VarChar
  updatedAt   DateTime? @map("updated_at") @db.Timestamp(6)
  updatedById String?   @map("updated_by_id") @db.Uuid
  url         String?   @map("url") @db.VarChar
  video       String?   @map("video") @db.VarChar

  @@index([adsGroupId], map: "ix_ads_ads_group_id")
  @@index([adsId], map: "ix_ads_ads_id")
  @@index([createdAt], map: "ix_ads_created_at")
  @@index([createdById], map: "ix_ads_created_by_id")
  @@index([endDate], map: "ix_ads_end_date")
  @@index([isDeleted], map: "ix_ads_is_deleted")
  @@index([lang], map: "ix_ads_lang")
  @@index([startDate], map: "ix_ads_start_date")
  @@index([updatedById], map: "ix_ads_updated_by_id")
  @@map("ads")
}

model AppStoreProductPrice {
  activatedAt DateTime @map("activated_at") @db.Timestamp(6)
  countryCode String   @map("country_code") @db.VarChar
  currency    String   @map("currency") @db.VarChar
  id          String   @id @default(uuid()) @map("id") @db.Uuid
  price       Float    @map("price")
  productCode String   @map("product_code") @db.VarChar

  @@unique([productCode, countryCode, activatedAt])
  @@index([activatedAt], map: "ix_app_store_product_price_activated_at")
  @@index([countryCode], map: "ix_app_store_product_price_country_code")
  @@index([productCode], map: "ix_app_store_product_price_product_code")
  @@map("app_store_product_price")
}

model Calendar {
  acroExpand     String?        @map("acro_expand") @db.VarChar
  actual         String?        @map("actual") @db.VarChar
  alsoCalled     String?        @map("also_called") @db.VarChar
  calendarText   CalendarText[]
  ccNotes        String?        @map("cc_notes") @db.VarChar
  ccNotice       String?        @map("cc_notice") @db.VarChar
  country        String?        @map("country") @db.VarChar
  countryCode    String?        @map("country_code") @db.VarChar
  createdAt      DateTime?      @default(now()) @map("created_at") @db.Timestamp(6)
  createdById    String?        @map("created_by_id") @db.Uuid
  dataEcobaseid  Int            @map("data_ecobaseid")
  dataEventId    Int            @map("data_event_id")
  date           DateTime?      @map("date") @db.Date
  derivedVia     String?        @map("derived_via") @db.VarChar
  description    String?        @map("description") @db.VarChar
  eventDatetime  DateTime?      @map("event_datetime") @db.Timestamp(6)
  forecast       String?        @map("forecast") @db.VarChar
  frequency      String?        @map("frequency") @db.VarChar
  id             String         @id @default(uuid()) @map("id") @db.Uuid
  impact         String?        @map("impact") @db.VarChar
  isDeleted      Boolean        @default(false) @map("is_deleted")
  measures       String?        @map("measures") @db.VarChar
  nextRelease    String?        @map("next_release") @db.VarChar
  previous       String?        @map("previous") @db.VarChar
  source         String?        @map("source") @db.VarChar
  speaker        String?        @map("speaker") @db.VarChar
  time           String?        @map("time") @db.VarChar
  title          String?        @map("title") @db.VarChar
  updatedAt      DateTime?      @map("updated_at") @db.Timestamp(6)
  updatedById    String?        @map("updated_by_id") @db.Uuid
  usualEffect    String?        @map("usual_effect") @db.VarChar
  whyTraderscare String?        @map("why_traderscare") @db.VarChar

  @@index([createdAt], map: "ix_calendar_created_at")
  @@index([createdById], map: "ix_calendar_created_by_id")
  @@index([isDeleted], map: "ix_calendar_is_deleted")
  @@index([updatedById], map: "ix_calendar_updated_by_id")
  @@map("calendar")
}

model CalendarText {
  acroExpand     String?  @map("acro_expand") @db.VarChar
  alsoCalled     String?  @map("also_called") @db.VarChar
  calendar       Calendar @relation(fields: [calendarId], references: [id])
  calendarId     String
  ccNotes        String?  @map("cc_notes") @db.VarChar
  ccNotice       String?  @map("cc_notice") @db.VarChar
  country        String?  @map("country") @db.VarChar
  derivedVia     String?  @map("derived_via") @db.VarChar
  description    String?  @map("description") @db.VarChar
  frequency      String?  @map("frequency") @db.VarChar
  id             String   @id @default(uuid()) @map("id") @db.Uuid
  language       String   @default("en") @map("language") @db.VarChar
  measures       String?  @map("measures") @db.VarChar
  source         String?  @map("source") @db.VarChar
  speaker        String?  @map("speaker") @db.VarChar
  title          String?  @map("title") @db.VarChar
  usualEffect    String?  @map("usual_effect") @db.VarChar
  whyTraderscare String?  @map("why_traderscare") @db.VarChar

  @@unique([calendarId, language])
  @@map("calendar_text")
}

model CanUpdate {
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  createdById String?   @map("created_by_id") @db.Uuid
  id          String    @id @default(uuid()) @map("id") @db.Uuid
  isDeleted   Boolean   @default(false) @map("is_deleted")
  language    String    @default("en") @map("language") @db.VarChar
  title       String?   @map("title") @db.VarChar
  updatedAt   DateTime? @map("updated_at") @db.Timestamp(6)
  updatedById String?   @map("updated_by_id") @db.Uuid

  @@index([createdAt], map: "ix_can_update_created_at")
  @@index([createdById], map: "ix_can_update_created_by_id")
  @@index([isDeleted], map: "ix_can_update_is_deleted")
  @@index([updatedById], map: "ix_can_update_updated_by_id")
  @@map("can_update")
}

model Clap {
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  createdById String?   @map("created_by_id") @db.Uuid
  id          String    @id @default(uuid()) @db.Uuid
  isDeleted   Boolean   @default(false) @map("is_deleted")
  setup       Setup?    @relation(fields: [setupId], references: [id])
  setupId     String?
  updatedAt   DateTime? @map("updated_at") @db.Timestamp(6)
  updatedById String?   @map("updated_by_id") @db.Uuid
  user        User?     @relation(fields: [userId], references: [id])
  userId      String?

  @@unique([userId, setupId])
  @@index([createdAt], map: "ix_clap_created_at")
  @@index([createdById], map: "ix_clap_created_by_id")
  @@index([isDeleted], map: "ix_clap_is_deleted")
  @@index([updatedById], map: "ix_clap_updated_by_id")
  @@map("clap")
}

model Coin {
  code        String    @unique @map("code") @db.VarChar
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  createdById String?   @map("created_by_id") @db.Uuid
  id          String    @id @default(uuid()) @map("id") @db.Uuid
  image       String?   @map("image") @db.VarChar
  isDeleted   Boolean   @default(false) @map("is_deleted")
  isFutures   Boolean   @default(true) @map("is_futures")
  isSpot      Boolean   @default(true) @map("is_spot")
  name        String    @map("name") @db.VarChar
  updatedAt   DateTime? @map("updated_at") @db.Timestamp(6)
  updatedById String?   @map("updated_by_id") @db.Uuid

  @@index([createdAt], map: "ix_coin_created_at")
  @@index([createdById], map: "ix_coin_created_by_id")
  @@index([isDeleted], map: "ix_coin_is_deleted")
  @@index([isFutures], map: "ix_coin_is_futures")
  @@index([isSpot], map: "ix_coin_is_spot")
  @@index([name], map: "ix_coin_name")
  @@index([updatedById], map: "ix_coin_updated_by_id")
  @@map("coin")
}

model CopyTradeOrder {
  actPx         Float?     @map("act_px")
  actSz         Float?     @map("act_sz")
  copyTrades    CopyTrade? @relation(fields: [copyTradeId], references: [id])
  copyTradeId   String?
  createdAt     DateTime?  @default(now()) @map("created_at") @db.Timestamp(6)
  createdById   String?    @map("created_by_id") @db.Uuid
  id            String     @id @default(uuid()) @map("id") @db.Uuid
  isDeleted     Boolean    @default(false) @map("is_deleted")
  percentage    Int?       @map("percentage")
  requestPx     Float?     @map("request_px")
  requestSz     Float?     @map("request_sz")
  requestedAt   DateTime?  @map("requested_at") @db.Timestamp(6)
  setup         Setup?     @relation(fields: [setupId], references: [id])
  setupId       String?
  side          String     @map("side") @db.VarChar(4)
  status        String     @map("status") @db.VarChar(20)
  statusAt      DateTime?  @map("status_at") @db.Timestamp(6)
  statusMessage String?    @map("status_message") @db.VarChar
  stopLossPx    Float?     @map("stop_loss_px")
  takeProfitPx  Float?     @map("take_profit_px")
  tpValue       String     @map("tp_value") @db.VarChar(3)
  updatedAt     DateTime?  @map("updated_at") @db.Timestamp(6)
  updatedById   String?    @map("updated_by_id") @db.Uuid
  user          User?      @relation(fields: [userId], references: [id])
  userId        String?

  @@unique([userId, setupId, side, tpValue])
  @@index([createdAt], map: "ix_copy_trade_order_created_at")
  @@index([createdById], map: "ix_copy_trade_order_created_by_id")
  @@index([isDeleted], map: "ix_copy_trade_order_is_deleted")
  @@index([side], map: "ix_copy_trade_order_side")
  @@index([status], map: "ix_copy_trade_order_status")
  @@index([tpValue], map: "ix_copy_trade_order_tp_value")
  @@index([updatedById], map: "ix_copy_trade_order_updated_by_id")
  @@map("copy_trade_order")
}

model CopyTrade {
  activatedAt    DateTime?        @map("activated_at") @db.Timestamp(6)
  assetSize      Float?           @map("asset_size")
  copiedAt       DateTime?        @map("copied_at") @db.Timestamp(6)
  copyTradeOrder CopyTradeOrder[]
  createdAt      DateTime?        @default(now()) @map("created_at") @db.Timestamp(6)
  createdById    String?          @map("created_by_id") @db.Uuid
  errorMessage   String?          @map("error_message") @db.VarChar
  errorNo        String?          @map("error_no") @db.VarChar
  id             String           @id @default(uuid()) @map("id") @db.Uuid
  isDeleted      Boolean          @default(false) @map("is_deleted")
  market         String?          @map("market") @db.VarChar
  realizedPnl    Float?           @map("realized_pnl")
  realizedR      Float?           @map("realized_r")
  setup          Setup?           @relation(fields: [setupId], references: [id])
  setupId        String?
  state          String?          @map("state") @db.VarChar
  trader         User?            @relation(name: "copyTradesCopyTradesTraderIdTouser", fields: [traderId], references: [id])
  traderId       String?
  updatedAt      DateTime?        @map("updated_at") @db.Timestamp(6)
  updatedById    String?          @map("updated_by_id") @db.Uuid
  usdSize        Float?           @map("usd_size")
  user           User?            @relation(name: "copyTradesCopyTradesUserIdTouser", fields: [userId], references: [id])
  userId         String?

  @@unique([userId, setupId])
  @@index([createdAt], map: "ix_copy_trades_created_at")
  @@index([createdById], map: "ix_copy_trades_created_by_id")
  @@index([isDeleted], map: "ix_copy_trades_is_deleted")
  @@index([market], map: "ix_copy_trades_market")
  @@index([state], map: "ix_copy_trades_state")
  @@index([updatedById], map: "ix_copy_trades_updated_by_id")
  @@map("copy_trades")
}

model FollowNotify {
  block       Boolean   @default(false) @map("block")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  createdById String?   @map("created_by_id") @db.Uuid
