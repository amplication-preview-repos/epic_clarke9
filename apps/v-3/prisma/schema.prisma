model WatchList {
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  createdById String?   @map("created_by_id") @db.Uuid
  id          String    @id @default(uuid()) @map("id") @db.Uuid
  isDeleted   Boolean   @default(false) @map("is_deleted")
  setup       Setup?    @relation(fields: [setupId], references: [id])
  setupId     String?
  updatedAt   DateTime? @map("updated_at") @db.Timestamp(6)
  updatedById String?   @map("updated_by_id") @db.Uuid
  user        User?     @relation(fields: [userId], references: [id])
  userId      String?

  @@unique([userId, setupId])
  @@index([createdAt], map: "ix_watch_list_created_at")
  @@index([createdById], map: "ix_watch_list_created_by_id")
  @@index([isDeleted], map: "ix_watch_list_is_deleted")
  @@index([updatedById], map: "ix_watch_list_updated_by_id")
  @@map("watch_list")
}

model Session {
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(6)
  hash      String    @map("hash") @db.VarChar
  id        String    @id @default(uuid()) @map("id") @db.Uuid
  updatedAt DateTime? @map("updated_at") @db.Timestamp(6)
  user      User      @relation(fields: [userId], references: [id])
  userId    String

  @@unique([hash], map: "ix_session_hash")
  @@index([createdAt], map: "ix_session_created_at")
  @@map("session")
}

enum EnumSetupCategory {
  spot
  futures
}

enum EnumSetupDuration {
  shortterm
  midterm
  longterm
}

enum EnumSetupPosition {
  long
  short
}

enum EnumSetupStatus {
  incoming
  active
  cancelled
  stopped
  success
  closed
}
