model Setup {
  activatedStopValue          Float?                     @map("activated_stop_value")
  activationDate              DateTime?                  @map("activation_date") @db.Timestamp(6)
  category                    EnumSetupCategory          @map("category")
  clap                        Clap[]
  clapCount                   Int?                       @map("clap_count")
  closeDate                   DateTime?                  @map("close_date") @db.Timestamp(6)
  closePrice                  Float?                     @map("close_price")
  closedById                  String?                    @map("closed_by_id") @db.Uuid
  coinName                    String                     @map("coin_name") @db.VarChar
  copyTradeOrder              CopyTradeOrder[]
  copyTrades                  CopyTrade[]
  createdAt                   DateTime?                  @default(now()) @map("created_at") @db.Timestamp(6)
  createdById                 String?                    @map("created_by_id") @db.Uuid
  duration                    EnumSetupDuration?         @map("duration")
  entryValue                  Float                      @map("entry_value")
  entryValueEnd               Float?                     @map("entry_value_end")
  id                          String                     @id @default(uuid()) @map("id") @db.Uuid
  image                       String?                    @map("image") @db.VarChar
  imageSuccess                String?                    @map("image_success") @db.VarChar
  initialEntryValue           Float?                     @map("initial_entry_value")
  initialEntryValueEnd        Float?                     @map("initial_entry_value_end")
  initialProfitTaking1        Float?                     @map("initial_profit_taking_1")
  initialProfitTaking2        Float?                     @map("initial_profit_taking_2")
  initialProfitTaking3        Float?                     @map("initial_profit_taking_3")
  initialProfitTakingAmount1  Float?                     @map("initial_profit_taking_amount_1")
  initialProfitTakingAmount2  Float?                     @map("initial_profit_taking_amount_2")
  initialProfitTakingAmount3  Float?                     @map("initial_profit_taking_amount_3")
  initialRr                   String?                    @map("initial_rr") @db.VarChar
  initialStopValue            Float?                     @map("initial_stop_value")
  isActive                    Boolean                    @default(true) @map("is_active")
  isDeleted                   Boolean                    @default(false) @map("is_deleted")
  isHidden                    Boolean                    @default(true) @map("is_hidden")
  isStop                      Boolean?                   @default(false) @map("is_stop")
  isTargeted                  Boolean                    @default(false) @map("is_targeted")
  isTp1                       Boolean?                   @default(false) @map("is_tp1")
  isTp2                       Boolean?                   @default(false) @map("is_tp2")
  isTp3                       Boolean?                   @default(false) @map("is_tp3")
  position                    EnumSetupPosition?         @map("position")
  previousEntryValue          Float?                     @map("previous_entry_value")
  previousEntryValueEnd       Float?                     @map("previous_entry_value_end")
  previousProfitTaking1       Float?                     @map("previous_profit_taking_1")
