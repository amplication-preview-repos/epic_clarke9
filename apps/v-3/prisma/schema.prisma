  traderId    String?
  updatedAt   DateTime? @map("updated_at") @db.Timestamp(6)
  updatedById String?   @map("updated_by_id") @db.Uuid
  user        User?     @relation(name: "followNotifyFollowNotifyUserIdTouser", fields: [userId], references: [id])
  userId      String?

  @@unique([userId, traderId])
  @@index([block], map: "ix_follow_notify_block")
  @@index([createdAt], map: "ix_follow_notify_created_at")
  @@index([createdById], map: "ix_follow_notify_created_by_id")
  @@index([follow], map: "ix_follow_notify_follow")
  @@index([isDeleted], map: "ix_follow_notify_is_deleted")
  @@index([notify], map: "ix_follow_notify_notify")
  @@index([updatedById], map: "ix_follow_notify_updated_by_id")
  @@map("follow_notify")
}

model Invitee {
  activatedAt DateTime? @map("activated_at") @db.Timestamp(6)
  id          String    @id @default(uuid()) @db.Uuid
  market      String?   @db.VarChar
  uid         String?   @db.VarChar

  @@unique([uid, market])
  @@index([market], map: "ix_invitees_market")
  @@index([uid], map: "ix_invitees_uid")
  @@map("invitees")
}

model News {
  createdAt    DateTime?  @default(now()) @map("created_at") @db.Timestamp(6)
  createdById  String?    @map("created_by_id") @db.Uuid
  date         DateTime?  @map("date") @db.Timestamp(6)
  fullText     String?    @map("full_text")
  id           String     @id @default(uuid()) @map("id") @db.Uuid
  imageURL     String?    @map("image_url") @db.VarChar
  isDeleted    Boolean    @default(false) @map("is_deleted")
  newsText     NewsText[]
  newsURL      String?    @map("news_url") @db.VarChar
  sentiment    String?    @map("sentiment") @db.VarChar
  sourceName   String?    @map("source_name") @db.VarChar
  text         String?    @map("text") @db.VarChar
  thumbnailURL String?    @map("thumbnail_url") @db.VarChar
  tickers      String     @map("tickers") @db.VarChar
  title        String?    @map("title") @db.VarChar
  topics       String     @map("topics") @db.VarChar
  typeField    String?    @map("type") @db.VarChar
  updatedAt    DateTime?  @map("updated_at") @db.Timestamp(6)
  updatedById  String?    @map("updated_by_id") @db.Uuid

  @@index([createdAt], map: "ix_news_created_at")
  @@index([createdById], map: "ix_news_created_by_id")
  @@index([isDeleted], map: "ix_news_is_deleted")
  @@index([updatedById], map: "ix_news_updated_by_id")
  @@map("news")
}

model NewsText {
  fullText String? @map("full_text")
  id       String  @id @default(uuid()) @map("id") @db.Uuid
  language String  @default("en") @map("language") @db.VarChar
  news     News    @relation(fields: [newsId], references: [id])
  newsId   String
  text     String? @map("text") @db.VarChar
  title    String? @map("title") @db.VarChar

  @@unique([newsId, language])
  @@map("news_text")
}

model Product {
  code                   String             @unique @map("code") @db.VarChar
  createdAt              DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  createdById            String?            @map("created_by_id") @db.Uuid
  discountedPrice        Float?             @map("discounted_price")
  duration               Int?               @map("duration")
  grossRevenue           Float?             @map("gross_revenue")
  id                     String             @id @default(uuid()) @map("id") @db.Uuid
  isDeleted              Boolean            @default(false) @map("is_deleted")
  name                   String             @map("name") @db.VarChar
  poolMoney              Float?             @map("pool_money")
  price                  Float?             @map("price")
  referralDiscount       Float?             @map("referral_discount")
  traderPoolRatio        Float?             @map("trader_pool_ratio")
  traderReferralEarnings Float?             @map("trader_referral_earnings")
  traderShareRatio       Float?             @map("trader_share_ratio")
  updatedAt              DateTime?          @map("updated_at") @db.Timestamp(6)
  updatedById            String?            @map("updated_by_id") @db.Uuid
  userSubscription       UserSubscription[]

  @@index([createdAt], map: "ix_product_created_at")
  @@index([createdById], map: "ix_product_created_by_id")
  @@index([isDeleted], map: "ix_product_is_deleted")
  @@index([name], map: "ix_product_name")
  @@index([updatedById], map: "ix_product_updated_by_id")
  @@map("product")
}

model ReferralCode {
